# ============================================================
# 한국투자증권 KIS Developers REST API
# https://apiportal.koreainvestment.com/
# ============================================================

# 실전/모의 모드 선택: REAL | PAPER
KIS_ENV=PAPER

# 실전투자 계정
KIS_REAL_APP_KEY=your_real_app_key_here
KIS_REAL_APP_SECRET=your_real_app_secret_here
KIS_REAL_ACCOUNT_NO=12345678-01

# 모의투자 계정
KIS_PAPER_APP_KEY=your_paper_app_key_here
KIS_PAPER_APP_SECRET=your_paper_app_secret_here
KIS_PAPER_ACCOUNT_NO=50123456-01

# REST / WebSocket 엔드포인트 (기본값 사용 권장)
KIS_REAL_BASE_URL=https://openapi.koreainvestment.com:9443
KIS_PAPER_BASE_URL=https://openapivts.koreainvestment.com:29443
KIS_REAL_WS_URL=ws://ops.koreainvestment.com:21000
KIS_PAPER_WS_URL=ws://ops.koreainvestment.com:31000

# HTS ID (실시간 시세 승인용)
KIS_HTS_ID=your_hts_id

# ============================================================
# Telegram Bot
# https://t.me/BotFather 로 토큰 발급
# ============================================================
TELEGRAM_BOT_TOKEN=123456:ABC-DEF_your_bot_token_here
TELEGRAM_CHAT_ID=123456789
TELEGRAM_ALERT_CHAT_ID=123456789

# ============================================================
# 트레이딩 파라미터
# ============================================================
TOTAL_SEED=10000000
MAX_CONCURRENT_POSITIONS=3
DAILY_LOSS_LIMIT_PCT=-10.0
STOP_LOSS_PCT=-5.0

# ============================================================
# 로깅 / DB
# ============================================================
LOG_LEVEL=INFO
LOG_DIR=./logs
DB_PATH=./db/trading.db
